# ============================================================
# StreaMindAI — Variabili d'ambiente
# Copia questo file in backend/.env e compila con i tuoi valori
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# URL del frontend
# Produzione: https://streamindai.com
# Dev locale:  http://localhost:5173
FRONTEND_URL=https://streamindai.com

# Origini CORS aggiuntive (opzionale, separare con virgola)
# CORS_ORIGINS=https://streamindai.com,https://www.streamindai.com

# ── Database PostgreSQL ───────────────────────────────────────
# Railway genera DATABASE_URL automaticamente
# Locale: postgresql://postgres:password@localhost:5432/streamindai
DATABASE_URL=postgresql://user:password@host:5432/database

# ── JWT ───────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_questa_stringa_con_una_chiave_sicura_di_almeno_64_caratteri

# ── Twitch OAuth ──────────────────────────────────────────────
# Crea app su: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=il_tuo_twitch_client_id
TWITCH_CLIENT_SECRET=il_tuo_twitch_client_secret

# Deve corrispondere esattamente all'URL registrato nella Twitch Console
# Produzione: https://streamindai.com/api/auth/twitch/callback
# Dev locale:  http://localhost:3001/api/auth/twitch/callback
TWITCH_REDIRECT_URI=https://streamindai.com/api/auth/twitch/callback

# ── Stripe ────────────────────────────────────────────────────
# Chiavi su: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_la_tua_chiave_segreta_stripe
STRIPE_WEBHOOK_SECRET=whsec_il_tuo_webhook_secret

# Endpoint webhook Stripe: https://streamindai.com/webhooks/stripe
# ID prezzi Stripe — 4 piani (crea prodotti su https://dashboard.stripe.com/products)
STRIPE_PRICE_STARTER=price_id_piano_starter_9eur
STRIPE_PRICE_CREATOR=price_id_piano_creator_19eur
STRIPE_PRICE_ELITE=price_id_piano_elite_35eur
STRIPE_PRICE_SIGNATURE=price_id_piano_signature_99eur
# Pacchetto messaggi aggiuntivi (one-time, 6€ — crea prodotto one-time su Stripe)
STRIPE_PRICE_TOKEN_PACK=price_id_token_pack_6eur

# ── Gemini API ────────────────────────────────────────────────
# Ottieni la chiave su: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=la_tua_gemini_api_key

# ── SMTP (email transazionali) ────────────────────────────────
# Mittente: noreply@streamindai.com — Reply-To: support@streamindai.com
# Usa Brevo, Mailgun, SendGrid o il tuo SMTP privato
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=la_tua_smtp_password
FROM_EMAIL=noreply@streamindai.com

# ── Spotify (per song request) ────────────────────────────────
# Crea app su: https://developer.spotify.com/dashboard
# Redirect URI da configurare: https://streamindai.com/api/spotify/callback
APP_URL=https://streamindai.com

# ── Twitch EventSub ───────────────────────────────────────────
TWITCH_BOT_USERNAME=username_account_bot_twitch
TWITCH_BOT_OAUTH=oauth:il_token_bot_twitch
TWITCH_BOT_USER_ID=id_account_bot_twitch
EVENTSUB_SECRET=scegli_una_stringa_segreta_per_eventsub

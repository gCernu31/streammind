# Server
PORT=3001
NODE_ENV=production

# URL del frontend
# Produzione: https://streamindai.com
# Dev locale:  http://localhost:5173
FRONTEND_URL=https://streamindai.com

# Database PostgreSQL (Railway genera DATABASE_URL automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/database

# Twitch OAuth
# Crea app su: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=il_tuo_twitch_client_id
TWITCH_CLIENT_SECRET=il_tuo_twitch_client_secret
# Redirect URI da registrare su dev.twitch.tv → Produzione
TWITCH_REDIRECT_URI=https://streamindai.com/api/auth/twitch/callback

# JWT (genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here

# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Endpoint webhook: https://streamindai.com/webhooks/stripe
STRIPE_PRICE_STARTER=price_id_starter
STRIPE_PRICE_CREATOR=price_id_creator
STRIPE_PRICE_ELITE=price_id_elite
STRIPE_PRICE_SIGNATURE=price_id_signature
# Pacchetto messaggi aggiuntivi (one-time, 6€)
STRIPE_PRICE_TOKEN_PACK=price_id_token_pack_6eur

# Gemini
GEMINI_API_KEY=la_tua_gemini_api_key

# SMTP — noreply@streamindai.com
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=la_tua_smtp_password
FROM_EMAIL=noreply@streamindai.com

# Spotify (redirect: https://streamindai.com/api/spotify/callback)
APP_URL=https://streamindai.com

# Twitch Bot + EventSub
TWITCH_BOT_USERNAME=username_account_bot_twitch
TWITCH_BOT_OAUTH=oauth:il_token_bot
TWITCH_BOT_USER_ID=id_account_bot
EVENTSUB_SECRET=scegli_una_stringa_segreta

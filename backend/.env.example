# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database PostgreSQL (Railway)
DATABASE_URL=postgresql://user:password@host:5432/database

# Twitch OAuth
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:3001/api/auth/twitch/callback

# JWT (genera una stringa casuale sicura)
JWT_SECRET=your_super_secret_jwt_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Prezzi Stripe (ID dei prodotti creati su Stripe Dashboard)
STRIPE_PRICE_BASE=price_base_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ELITE=price_elite_id
